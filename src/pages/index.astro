---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSenseAfterIntro from '../components/AdSenseAfterIntro.astro';
const pageTitle = "Sonic Fan Games - Download & Play 70+ Free Fangames";
const pageDescription = "Browse the best collection of Sonic fan games. Download free fangames for PC and Android — 3D adventures, 2D platformers, fighting games, kart racers, and beyond.";
const pageCanonical = "https://sonic-fangames.com/";
const pageLang = "en";
const pageHreflangs = [
  { lang: "en", url: "https://sonic-fangames.com/" },
  { lang: "es", url: "https://sonic-fangames.com/es/descargar/" },
  { lang: "pt", url: "https://sonic-fangames.com/pt/baixar/" },
  { lang: "x-default", url: "https://sonic-fangames.com/" }
];
const pageHeading = "Sonic Fan Games";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageCanonical}
  lang={pageLang}
  hreflangs={pageHreflangs}
  heading={pageHeading}
>
<Fragment set:html={`<div class="description-section"><strong>The largest collection of Sonic fan games, ROM hacks, and mods — all free to download and play.</strong> From full-length 2D platformers and 3D adventures to fighting games, kart racers, and total engine rebuilds, everything here is made by the community that keeps pushing Sonic forward.
<div class="intro-buttons"><a href="#featured" class="intro-btn">Featured Fan Games</a><a href="#tier-list" class="intro-btn">Fan Games Tier-List</a><a href="#get-started" class="intro-btn">How to Get Started</a></div></div>`} />
<AdSenseAfterIntro />
<Fragment set:html={`

<style>
.fg-gallery{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin:20px 0 32px}
.fg-card{display:flex;align-items:center;gap:14px;background:#f0f4ff;border:1px solid #e2e5ea;border-radius:12px;padding:12px;text-decoration:none;color:#1a1d2e;transition:border-color .2s,transform .15s}
.fg-card:hover{border-color:#6366f1;transform:translateY(-2px)}
.fg-card-img{width:179px;min-width:179px;height:101px;object-fit:cover;border-radius:8px}
.fg-card-info{flex:1;min-width:0}
.fg-card-head{display:flex;align-items:center;gap:8px;margin:0 0 4px;justify-content:space-between;flex-wrap:wrap}
.fg-card-title{font-size:20px;font-weight:700;color:#111;margin:0;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0;flex:1}
.fg-tags{display:flex;gap:4px;flex-shrink:0}
.fg-tag{font-size:12px;font-weight:600;padding:3px 8px;border-radius:4px;background:#dbe4ff;color:#3b5998;white-space:nowrap;line-height:1.4}
.fg-card-desc{font-size:14px;color:#64748b;line-height:1.4;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
@media(max-width:900px){.fg-gallery{grid-template-columns:1fr}}
@media(max-width:768px){.fg-card-img{width:150px;min-width:150px;height:84px}.fg-card-title{font-size:17px}.fg-card-head{flex-direction:column;align-items:flex-start;gap:4px}.fg-tags{order:1}}
.fg-filters{display:flex;gap:8px;margin:0 0 16px;flex-wrap:wrap;justify-content:center}
.fg-filter{font-size:16px;font-weight:600;padding:6px 17px;border-radius:6px;border:1px solid #e2e5ea;background:#fff;color:#475569;cursor:pointer;transition:all .2s;user-select:none}
.fg-filter:hover{border-color:#6366f1;color:#6366f1}
.fg-filter.active{background:#6366f1;color:#fff;border-color:#6366f1}
.fg-filter-sep{width:1px;height:24px;background:#d1d5db;align-self:center}
.fg-card.fg-hidden{display:none}
.fg-counter{text-align:center;font-size:14px;color:#64748b;margin:-8px 0 12px}
.fg-empty{display:none;text-align:center;padding:32px 16px;color:#94a3b8;font-size:15px}
.fg-empty.visible{display:block}
@media(max-width:400px){.fg-card{gap:10px;padding:10px}.fg-card-img{width:115px;min-width:115px;height:64px}.fg-card-title{font-size:15px}.fg-tag{font-size:10px;padding:2px 6px}}
/* Tier S cards */
.tier-s-card{background:#f0f4ff;border:2px solid #dbe4ff;border-radius:16px;padding:24px;margin:0 0 20px;transition:border-color .2s}
.tier-s-card:hover{border-color:#6366f1}
.tier-s-card h4{font-size:1.4em;margin:0 0 8px;color:#1F50EA}
.tier-s-card h4 a{color:#1F50EA;text-decoration:none}
.tier-s-card h4 a:hover{text-decoration:underline}
.tier-s-card .tier-s-badge{display:inline-block;background:#6366f1;color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px;margin-left:8px;vertical-align:middle;letter-spacing:.5px}
.tier-s-card>p{font-size:1em;line-height:1.6;color:#444;margin:0 0 16px}
.tier-s-previews{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.tier-s-previews img{width:100%;height:auto;border-radius:8px;aspect-ratio:16/9;object-fit:cover}
@media(max-width:768px){.tier-s-card{padding:16px}.tier-s-card h4{font-size:1.2em}.tier-s-previews{gap:6px}}
@media(max-width:480px){.tier-s-previews{grid-template-columns:1fr}.tier-s-previews img{aspect-ratio:16/9}}
/* Types grid */
.types-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:20px 0 32px}
.type-card{background:#f0f4ff;border:1px solid #dbe4ff;border-radius:12px;padding:20px;transition:border-color .2s,transform .15s}
.type-card:hover{border-color:#6366f1;transform:translateY(-2px)}
.type-card h3{font-size:1.1em;color:#1F50EA;margin:0 0 8px;text-align:left}
.type-card p{font-size:.95em;line-height:1.5;color:#444;margin:0;text-align:left}
.type-card a{color:#1F50EA;text-decoration:none;font-weight:600}
.type-card a:hover{text-decoration:underline}
@media(max-width:900px){.types-grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.types-grid{grid-template-columns:1fr}}
.tier-a-badge{display:inline-block;background:#f59e0b;color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px;margin-left:8px;vertical-align:middle;letter-spacing:.5px}
.stats-table{font-size:.97em}
.stats-table tbody tr td:last-child{font-weight:400}
.description-section{padding:20px 40px;margin:15px auto}
.intro-buttons{display:flex;gap:8px;margin:12px 0 0;flex-wrap:wrap;justify-content:center}
.description-section a.intro-btn{padding:6px 18px;font-size:13px;font-weight:600;border-radius:4px;letter-spacing:.3px;margin-top:0;box-shadow:none;transition:background .2s,transform .15s}
.description-section a.intro-btn:hover{background:#1a3fc0;transform:translateY(-1px);box-shadow:none}
.columna{background:#f0f4ff;border:1px solid #dbe4ff;border-radius:12px;padding:6px;text-align:center;transition:border-color .2s,transform .15s}
.columna:hover{border-color:#6366f1;transform:translateY(-2px)}
.columna .imagen-redondeada{margin:0 auto}
.columna .texto-imagen{font-size:14px;font-weight:600;color:#1a1d2e;margin:6px 0 2px}
</style>

<h2 id="featured">Featured Sonic Fan Games</h2>
<div class="fg-filters">
<button class="fg-filter active" data-filter="all">All</button>
<button class="fg-filter" data-filter="Windows">Windows</button>
<button class="fg-filter" data-filter="Android">Android</button>
<button class="fg-filter" data-filter="PS4/PS5">PS4/PS5</button>
<button class="fg-filter" data-filter="2D">2D</button>
<button class="fg-filter" data-filter="3D">3D</button>
<span class="fg-filter-sep"></span>
<button class="fg-filter" data-filter="Platformer">Platformer</button>
<button class="fg-filter" data-filter="Fighting">Fighting</button>
<button class="fg-filter" data-filter="Racing">Racing</button>
</div>
<p class="fg-counter">Showing <span id="fg-count">30</span> of 30 games</p>
<div class="fg-gallery">
<p class="fg-empty">No games match the selected filters.</p>
<a href="/robo-blast-2/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2024/08/Sonic-Robo-Blast-2-300x188-300w.webp" alt="Sonic Robo Blast 2" loading="eager" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Robo Blast 2</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">The greatest 3D Sonic fan game ever made, built on a modified Doom engine with 25+ levels, three playable characters, 32-player online multiplayer, and over 1,000 community mods.</p></div>
</a>
<a href="/sonic-p-06/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-p-06/p06-intro.webp" alt="Sonic P-06" loading="eager" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic P-06</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A ground-up reconstruction of Sonic 2006 built in Unity, featuring all three campaigns (Sonic, Shadow, Silver), 9 playable characters, rebuilt physics, and visuals that surpass official Sonic titles.</p></div>
</a>
<a href="/sonic-triple-trouble-16-bit/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/triple-trouble-16-bit/intro.webp" alt="Sonic Triple Trouble 16-Bit" loading="eager" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Triple Trouble 16-Bit</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A five-year fan remake that reimagines the 1994 Game Gear exclusive as a full Sega Genesis adventure, featuring real-time character swapping, five playable characters, and level design that rivals Sonic 3 &amp; Knuckles.</p></div>
</a>
<a href="/sonic-gt/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-gt/sonic-gt-intro.webp" alt="Sonic GT" loading="eager" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic GT</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A momentum-driven 3D fan game built on the custom Bumper Engine with 4 massive zones, 7 playable characters, and physics-based level design where every bit of speed is earned through terrain and player skill.</p></div>
</a>
<a href="/3-air/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/3-air/sonic-3-air-intro.webp" alt="Sonic 3 A.I.R." loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic 3 A.I.R.</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A fan-made remaster of the legendary Sonic 3 &amp; Knuckles with widescreen 16:9, HD rendering at 60fps, remastered music options, extensive customization, and a massive mod ecosystem.</p></div>
</a>
<a href="/sonic-time-twisted/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-time-twisted/time-twisted-intro.webp" alt="Sonic Time Twisted" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Time Twisted</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A massive original 2D fan game that merges Sonic CD's time travel mechanics with the momentum-based level design of Sonic 3 &amp; Knuckles, delivering 8 zones, 28 acts, 10 bosses, and multiple endings.</p></div>
</a>
<a href="/sonic-before-the-sequel/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/before-the-sequel/bts-intro.webp" alt="Sonic Before the Sequel" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Before the Sequel</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A legendary 2D fan game bridging Sonic 1 and Sonic 2, rebuilt from the ground up with Genesis-quality controls, original zones, memorable boss fights, and one of the most iconic soundtracks in fan gaming history.</p></div>
</a>
<a href="/sonic-after-the-sequel/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/after-the-sequel/sonic-after-the-sequel-intro.webp" alt="Sonic After the Sequel" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic After the Sequel</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A full-length 2D adventure filling the gap between Sonic 2 and Sonic 3 &amp; Knuckles, featuring a completely different mechanic in every level, varied boss fights, and an entirely original soundtrack.</p></div>
</a>
<a href="/sonic-daybreak/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-daybreak/sonic-daybreak-intro.webp" alt="Sonic Daybreak" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Daybreak</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A stunning 3D fangame built in Unreal Engine that fuses momentum-driven classic physics with Modern Sonic's speed and Adventure-style exploration, featuring three dense multi-path stages.</p></div>
</a>
<a href="/sonic-and-the-fallen-star/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/fallen-star/fallen-star-intro.webp" alt="Sonic and the Fallen Star" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic and the Fallen Star</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A complete 2D fangame with 9 full zones, entirely original custom sprites, animated cutscenes, a dual original soundtrack, and a unique super transformation called Nova Sonic.</p></div>
</a>
<a href="/sonic-definitive/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-definitive/sonic-definitive-intro.webp" alt="Sonic Definitive" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Definitive</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A cinematic 2D boost-style fangame inspired by Sonic Rush, featuring layered combat, cinematic action sequences mid-gameplay, and a multi-phase Mecha Sonic boss fight packed into a highly polished zone.</p></div>
</a>
<a href="/sonic-rush-rerun/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-rush-rerun/sonic-rush-rerun-intro.webp" alt="Sonic Rush Rerun" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Rush Rerun</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A fan-made 2.5D reimagining of Sonic Rush rebuilt for PC with low-poly 3D visuals, combining the best mechanics from Rush, Rush Adventure, and Colors DS with native 144hz+ support.</p></div>
</a>
<a href="/dr-robotniks-ring-racers/" class="fg-card" data-genre="Racing">
<img class="fg-card-img" src="/wp-content/uploads/2026/ring-racers/ring-racers-intro.webp" alt="Dr. Robotnik's Ring Racers" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Dr. Robotnik's Ring Racers</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A free, technically demanding kart racer built on the Doom engine featuring 233 tracks, 54+ characters, 24 items, online multiplayer with voice chat, and full mod support.</p></div>
</a>
<a href="/sonic-encore/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-encore/sonic-encore-intro.webp" alt="Sonic Encore" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Encore</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A passion project that rebuilds iconic zones from the classic 2D Sonic games as full 3D levels, delivering 6 zones, 12 acts, boss fights, and 6 playable characters with momentum-driven physics.</p></div>
</a>
<a href="/sonic-megamix-mania/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/megamix-mania/megamix-mania-intro.webp" alt="Sonic Megamix Mania" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Megamix Mania</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A massive Sonic Mania Plus mod that reimagines the legendary Megamix ROM hack with 6 fully redesigned zones, 6 playable characters with distinct abilities, and professional-grade pixel art.</p></div>
</a>
<a href="/smackdown/" class="fg-card" data-genre="Fighting">
<img class="fg-card-img" src="/wp-content/uploads/2024/smackdown/ultimate-art-intro.webp" alt="Ultimate Sonic Smackdown" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Smackdown</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A full-fledged Sonic fighting game built on Unreal Engine with a complete roster, unique movesets, flashy supers, plus its sequel Ultimate with tag team 2v2/3v3 format and rollback netcode.</p></div>
</a>
<a href="/world-dx/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2024/04/Sonic-World-DX_Fangame-200w.webp" alt="Sonic World DX" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic World DX</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A free 3D sandbox fangame inspired by Sonic Adventure and Sonic Heroes, packed with 39 playable characters, 52 level acts across 12 stages, a Chao Garden, and team companion mechanics.</p></div>
</a>
<a href="/sonic-dimensions/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-dimensions/dimensions-intro.webp" alt="Sonic Dimensions" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Dimensions</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A unique 2D boost platformer that pairs Sonic Advance-style GBA pixel art with modern boost mechanics, featuring 7 zones connected by a hub world, a skill shop, and Super/Hyper transformations.</p></div>
</a>
<a href="/sonic-x-treme-unity/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-x-treme-unity/xtreme-intro.webp" alt="Sonic X-Treme Unity" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic X-Treme Unity</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A fan-made recreation of the most famous cancelled Sonic game, originally planned for the Sega Saturn in 1996. Rebuilt in Unity with four surreal zones and the iconic fisheye camera perspective.</p></div>
</a>
<a href="/sonic-battle-r/" class="fg-card" data-genre="Racing">
<img class="fg-card-img" src="/wp-content/uploads/2026/sonic-battle-r/battle-r-intro.webp" alt="Sonic Battle R" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Battle R</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A high-speed 3D racing and combat fangame where every race is a chaotic brawl at 300 mph. Features over 60 tracks, online multiplayer, Chaos-powered combat abilities, and guest characters.</p></div>
</a>
<a href="/momentum/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/momentum/momentum-intro.webp" alt="Sonic Momentum" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Momentum</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">Android</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A 2D fan game that reimagines Sonic Frontiers' cyber space stages through the lens of the Advance and Rush era, featuring 7 stages, 3 playable characters, and a full combo-based combat system.</p></div>
</a>
<a href="/galactic/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/galactic/galactic-intro.webp" alt="Sonic Galactic" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Galactic</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">2D</span></div></div><p class="fg-card-desc">A Saturn-era inspired 2D platformer with hand-pixeled art, five playable characters including an original mole named Tunnel, and a vertical level design philosophy widely called the Sonic Mania successor.</p></div>
</a>
<a href="/rush-3d/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/rush-3d/rush-3d-intro.webp" alt="Sonic Rush 3D" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Rush 3D</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A fan-made 3D reimagining of the Nintendo DS classic Sonic Rush, rebuilding Leaf Storm into a full 3D platformer in Unity with boost mechanics, aerial trick combos, and a low-poly DS-era art style.</p></div>
</a>
<a href="/project-reignition/" class="fg-card">
<img class="fg-card-img" src="/wp-content/uploads/2026/project-reignition/reignition-intro.webp" alt="Sonic Project Reignition" loading="lazy" />
<div class="fg-card-info"><div class="fg-card-head"><p class="fg-card-title">Sonic Project Reignition</p><div class="fg-tags"><span class="fg-tag">Windows</span><span class="fg-tag">3D</span></div></div><p class="fg-card-desc">A ground-up fan remake of Sonic and the Secret Rings built in Godot, replacing all motion controls with modern gamepad input. Features six playable worlds, boss fights, and 50+ abilities.</p></div>
</a>
